            .add_sub_state::<states::GameReadyGameReadyMenuOptions>()
            .add_sub_state::<states::GameReadyGame>()
            .add_sub_state::<states::GameReadyGameReadyGamePlaying>()
            .add_sub_state::<states::GameReadyGameReadyGamePaused>()
            .add_sub_state::<states::GameReadyGameReadyGameOver>()
        ;
